# ===== Configuracao geral =====
# Seu nome (usado nas mensagens automaticas)
OWNER_NAME=Ze

# ===== Telegram =====
# Token do bot, obtido com o @BotFather no Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz

# Em grupos, so responder/encaminhar quando o bot for mencionado (@) ou citado (reply) (true/false)
ONLY_WHEN_MENTIONED_IN_GROUPS=true
# Tempo minimo (em horas) antes de encaminhar nova pergunta do mesmo chat
FORWARD_COOLDOWN_HOURS=1

# ===== E-mail de destino =====
# E-mail para onde as perguntas serao encaminhadas
FORWARD_TO_EMAIL=ze.rosquinha3@gmail.com

# ===== SMTP (Gmail) para envio de e-mail =====
# Use uma "Senha de app" do Gmail (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-do-gmail
# Remetente exibido no e-mail (opcional; padrao usa SMTP_USER)
MAIL_FROM="Bot Telegram <seu-email@gmail.com>"
