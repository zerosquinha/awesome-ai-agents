# ===== Configuracao geral =====
# Seu nome (usado nas mensagens automaticas)
OWNER_NAME=Ze

# ===== Bot 1: Aviso de ausencia =====
# Liga/desliga o aviso automatico de ausencia (true/false)
ENABLE_AWAY_NOTICE=true
# Nao enviar o aviso automatico nos fins de semana (pois voce costuma estar online)
SKIP_AWAY_ON_WEEKEND=true
# Tempo minimo (em horas) antes de reenviar o aviso para o mesmo contato
AWAY_COOLDOWN_HOURS=12

# ===== Bot 2: Encaminhamento de perguntas por e-mail =====
# Liga/desliga o encaminhamento de perguntas (true/false)
ENABLE_FORWARD_QUESTIONS=true
# E-mail para onde as perguntas serao encaminhadas
FORWARD_TO_EMAIL=ze.rosquinha3@gmail.com

# Em grupos, so encaminhar quando o bot for mencionado (@) (true/false)
FORWARD_ONLY_WHEN_MENTIONED_IN_GROUPS=true
# Tempo minimo (em horas) antes de encaminhar nova pergunta do mesmo contato
FORWARD_COOLDOWN_HOURS=1

# ===== SMTP (Gmail) para envio de e-mail =====
# Use uma "Senha de app" do Gmail (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app-do-gmail
# Remetente exibido no e-mail (opcional; padrao usa SMTP_USER)
MAIL_FROM="Bot WhatsApp <seu-email@gmail.com>"
